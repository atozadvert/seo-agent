# SEO Guardian Configuration (.env)
# Copy this file to .env and fill in your credentials

# ═══════════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (Required for reports)
# ═══════════════════════════════════════════════════════════════════
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
REPORT_EMAIL=info@atozadvert.com

# ═══════════════════════════════════════════════════════════════════
# WHATSAPP ALERTS (Twilio - Optional but recommended)
# ═══════════════════════════════════════════════════════════════════
# Sign up at https://twilio.com and get WhatsApp sandbox credentials
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
MY_WHATSAPP_NUMBER=whatsapp:+923001234567

# ═══════════════════════════════════════════════════════════════════
# SLACK NOTIFICATIONS (Optional)
# ═══════════════════════════════════════════════════════════════════
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_BOT_TOKEN=xoxb-your-bot-token

# ═══════════════════════════════════════════════════════════════════
# GOOGLE APIs
# ═══════════════════════════════════════════════════════════════════
# Google Search Console - Use service account for Railway deployment
GSC_SERVICE_ACCOUNT_JSON=base64_encoded_service_account_json
GOOGLE_PAGESPEED_API=your_google_pagespeed_api_key

# ═══════════════════════════════════════════════════════════════════
# SEO TOOLS APIs (Optional - uses mock data if not provided)
# ═══════════════════════════════════════════════════════════════════
SEMRUSH_API_KEY=your_semrush_api_key
AHREFS_API_KEY=your_ahrefs_api_key
VALUESERP_API_KEY=your_valueserp_api_key

# ═══════════════════════════════════════════════════════════════════
# AI RECOMMENDATIONS (Optional - Claude API)
# ═══════════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=your_anthropic_api_key

# ═══════════════════════════════════════════════════════════════════
# GOOGLE BUSINESS PROFILE API (Optional)
# ═══════════════════════════════════════════════════════════════════
GOOGLE_BUSINESS_API_KEY=your_google_business_api_key
